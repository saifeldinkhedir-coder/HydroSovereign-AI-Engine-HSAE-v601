# HSAE v10.0 — Environment Variables Example
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# NEVER commit .env to git!

# ── Telegram Alerts ────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Google Earth Engine ────────────────────────────────────────────
GEE_PROJECT=zinc-arc-484714-j8
# Run once: earthengine authenticate

# ── NASA Earthdata (GRACE-FO, SMAP) ───────────────────────────────
# Register at: https://urs.earthdata.nasa.gov/users/new
# Then add to ~/.netrc:
#   machine urs.earthdata.nasa.gov login YOUR_USER password YOUR_PASS
EARTHDATA_USER=your_username
EARTHDATA_PASS=your_password

# ── Copernicus CDS (GloFAS) ────────────────────────────────────────
# Register at: https://cds.climate.copernicus.eu
# Then create ~/.cdsapirc with your UID:API_KEY
CDS_URL=https://cds.climate.copernicus.eu/api/v2
CDS_KEY=your_uid:your_api_key

# ── HSAE API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# ── Data paths ─────────────────────────────────────────────────────
GRDC_DATA_DIR=HSAE_Data
GEE_OUTPUT_DIR=data/gee
